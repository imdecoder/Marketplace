@Marketplace_HostAddress = http://localhost:5190

### Create Sample Order 1
POST {{Marketplace_HostAddress}}/api/orders
Content-Type: application/json

{
  "platform": "Trendyol",
  "date": "2026-03-03T10:00:00Z",
  "items": [
    {
      "name": "Laptop",
      "purchasePrice": 10000,
      "salePrice": 15000,
      "commissionRate": 10,
      "shippingCost": 100,
      "quantity": 2
    },
    {
      "name": "Mouse",
      "purchasePrice": 200,
      "salePrice": 150,
      "commissionRate": 5,
      "shippingCost": 20,
      "quantity": 5
    }
  ]
}

